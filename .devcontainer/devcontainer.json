{
  "name": "Dart Project",
  "image": "dart:latest",
  "customizations": {
    "vscode": {
      "extensions": [
        "dart-code.dart-code"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "[dart]": {
          "editor.defaultFormatter": "Dart-Code.dart-code"
        }
      }
    }
  }
}